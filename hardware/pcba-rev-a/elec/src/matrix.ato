    sel_p2.daq_2 ~ daq_2
    sel_p3.daq_2 ~ daq_2
    sel_p4.daq_2 ~ daq_2
    sel_kfp.daq_2 ~ daq_2
    sel_kfn.daq_2 ~ daq_2
    sel_ksp.daq_2 ~ daq_2
    sel_ksn.daq_2 ~ daq_2
    sel_p1.logic_1 ~ logic_1
    sel_p2.logic_1 ~ logic_1
    sel_p3.logic_1 ~ logic_1
    sel_p4.logic_1 ~ logic_1
