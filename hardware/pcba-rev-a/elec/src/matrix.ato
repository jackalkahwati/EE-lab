    sel_ksp.sink_bank ~ sink_ksp_bank
    sel_ksp.sink_scope_a ~ sink_ksp_scope_a
    sel_ksp.sink_scope_b ~ sink_ksp_scope_b
    sel_ksp.sink_daq_1 ~ sink_ksp_daq_1
    sel_ksp.sink_daq_2 ~ sink_ksp_daq_2
    sel_ksp.sink_logic_1 ~ sink_ksp_logic_1
    sel_ksp.sink_logic_2 ~ sink_ksp_logic_2
    sel_ksp.sink_pwr ~ sink_ksp_pwr
    sel_ksp.sink_dmm_hi ~ sink_ksp_dmm_hi
    sel_ksp.sink_dmm_lo ~ sink_ksp_dmm_lo
    sel_ksp.sink_gnd ~ sink_ksp_gnd
    sel_ksn.sink_bank ~ sink_ksn_bank
    sel_ksn.sink_scope_a ~ sink_ksn_scope_a
    sel_ksn.sink_scope_b ~ sink_ksn_scope_b
    sel_ksn.sink_daq_1 ~ sink_ksn_daq_1
    sel_ksn.sink_daq_2 ~ sink_ksn_daq_2
    sel_ksn.sink_logic_1 ~ sink_ksn_logic_1
