    sel_kfp.sink_dmm_lo ~ sink_kfp_dmm_lo
    sel_kfp.sink_gnd ~ sink_kfp_gnd
    sel_kfn.sink_bank ~ sink_kfn_bank
    sel_kfn.sink_scope_a ~ sink_kfn_scope_a
    sel_kfn.sink_scope_b ~ sink_kfn_scope_b
    sel_kfn.sink_daq_1 ~ sink_kfn_daq_1
    sel_kfn.sink_daq_2 ~ sink_kfn_daq_2
