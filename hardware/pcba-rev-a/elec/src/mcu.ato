    sr11.VCC ~ v3v3.hv
    sr12.VCC ~ v3v3.hv
    sr1.GND ~ v3v3.lv
    sr2.GND ~ v3v3.lv
    sr3.GND ~ v3v3.lv
    sr4.GND ~ v3v3.lv
    sr5.GND ~ v3v3.lv
    sr6.GND ~ v3v3.lv
    sr7.GND ~ v3v3.lv
    sr8.GND ~ v3v3.lv
    sr9.GND ~ v3v3.lv
    sr10.GND ~ v3v3.lv
    sr11.GND ~ v3v3.lv
    sr12.GND ~ v3v3.lv
    sr1.nSRCLR ~ v3v3.hv
    sr2.nSRCLR ~ v3v3.hv
    sr3.nSRCLR ~ v3v3.hv
    sr4.nSRCLR ~ v3v3.hv
    sr5.nSRCLR ~ v3v3.hv
    sr6.nSRCLR ~ v3v3.hv
    sr7.nSRCLR ~ v3v3.hv
    sr8.nSRCLR ~ v3v3.hv
    sr9.nSRCLR ~ v3v3.hv
    sr10.nSRCLR ~ v3v3.hv
    sr11.nSRCLR ~ v3v3.hv
    sr12.nSRCLR ~ v3v3.hv

    # coil sink channel map (chain order; firmware shares this table)
    sr1.DRAIN0 ~ drain1
    sr1.DRAIN1 ~ drain2
    sr1.DRAIN2 ~ drain3
    sr1.DRAIN3 ~ drain4
    sr1.DRAIN4 ~ drain5
    sr1.DRAIN5 ~ drain6
    sr1.DRAIN6 ~ drain7
    sr1.DRAIN7 ~ drain8
    sr2.DRAIN0 ~ drain9
    sr2.DRAIN1 ~ drain10
