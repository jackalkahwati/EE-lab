    sr3.nG ~ mcu.oe_n
    sr4.nG ~ mcu.oe_n
    sr5.nG ~ mcu.oe_n
    sr6.nG ~ mcu.oe_n
    sr7.nG ~ mcu.oe_n
    sr8.nG ~ mcu.oe_n
    sr9.nG ~ mcu.oe_n
    sr10.nG ~ mcu.oe_n
    sr11.nG ~ mcu.oe_n
    sr12.nG ~ mcu.oe_n
    sr1.VCC ~ v3v3.hv
    sr2.VCC ~ v3v3.hv
    sr3.VCC ~ v3v3.hv
    sr4.VCC ~ v3v3.hv
