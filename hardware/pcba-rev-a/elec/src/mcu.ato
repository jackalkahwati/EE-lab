    sr9.SRCK ~ mcu.spi_sck
    sr10.SRCK ~ mcu.spi_sck
    sr11.SRCK ~ mcu.spi_sck
    sr12.SRCK ~ mcu.spi_sck
    sr1.RCK ~ mcu.latch
    sr2.RCK ~ mcu.latch
    sr3.RCK ~ mcu.latch
    sr4.RCK ~ mcu.latch
    sr5.RCK ~ mcu.latch
    sr6.RCK ~ mcu.latch
